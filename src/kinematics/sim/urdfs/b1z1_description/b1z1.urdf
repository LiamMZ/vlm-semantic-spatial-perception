  <!-- ==================== Z1 ARM ==================== -->
  <!-- Arm mount: centered front-top of B1 trunk -->
  <!-- trunk_length ~= 0.647m, trunk_height ~= 0.114m -->
  <!-- arm_offset_x = trunk_length/2 - 0.07 = 0.2535 -->
  <!-- arm_offset_z = trunk_height/2 = 0.057 -->
  <joint name="trunk_arm_joint" type="fixed">
